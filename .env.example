# LernortAI – Umgebungsvariablen Vorlage
# Kopiere diese Datei nach .env und fülle die Werte aus.
# Die Datei .env wird NICHT ins Git-Repository eingecheckt.
#
# Diese Werte werden in Vercel unter Settings → Environment Variables gesetzt.

# -------------------------------------------------------
# Anthropic / Claude API
# https://console.anthropic.com → API Keys
# -------------------------------------------------------

# Anthropic API-Key für KI-Korrektur (wird nur serverseitig verwendet)
ANTHROPIC_API_KEY=sk-ant-...

# -------------------------------------------------------
# CORS-Schutz für den API-Proxy (/api/claude)
# Komma-separierte Liste der erlaubten Origins
# Beispiel: https://meine-app.vercel.app,https://lernortai.ch
# -------------------------------------------------------
ALLOWED_ORIGINS=https://DEINE-DOMAIN.vercel.app

# -------------------------------------------------------
# App-Einstellungen (optional)
# -------------------------------------------------------

# Schulname (wird in der App angezeigt)
SCHOOL_NAME=Berufsschule Musterstadt
