# LernortAI – Umgebungsvariablen Vorlage
# Kopiere diese Datei nach .env und fülle die Werte aus.
# Die Datei .env wird NICHT ins Git-Repository eingecheckt.
#
# HINWEIS: Diese App ist eine Single-Page-App (SPA).
# Die Werte werden beim Vercel-Build via build.js in index.html eingebettet.
# Dadurch müssen Nutzer Supabase URL und Key NICHT mehr manuell eingeben.
# Setze alle Variablen in Vercel unter: Settings → Environment Variables

# -------------------------------------------------------
# Supabase Konfiguration
# https://app.supabase.com → Settings → API
# -------------------------------------------------------

# Deine Supabase Projekt-URL
# Format: https://<project-ref>.supabase.co
SUPABASE_URL=https://DEIN-PROJEKT.supabase.co

# Supabase anonymer (öffentlicher) API-Key
# Unter: Settings → API → Project API keys → anon public
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -------------------------------------------------------
# Anthropic / Claude API
# https://console.anthropic.com → API Keys
# -------------------------------------------------------

# Anthropic API-Key für KI-Korrektur
# Wird als Vercel Environment Variable gesetzt (NICHT im Browser gespeichert).
# In Vercel: Settings → Environment Variables → ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=sk-ant-...

# -------------------------------------------------------
# App-Einstellungen
# -------------------------------------------------------

# Applikations-Passwort (einfacher Zugriffsschutz)
# Wenn gesetzt, wird das Passwort beim ersten Login automatisch gesetzt.
APP_PASSWORD=mein-sicheres-passwort

# Schulname (wird in der App angezeigt)
SCHOOL_NAME=Berufsschule Musterstadt
