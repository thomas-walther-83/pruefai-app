# LernortAI – Umgebungsvariablen Vorlage
# Kopiere diese Datei nach .env und fülle die Werte aus.
# Die Datei .env wird NICHT ins Git-Repository eingecheckt.
#
# Diese Werte werden in Vercel unter Settings → Environment Variables gesetzt.

# -------------------------------------------------------
# Anthropic / Claude API
# https://console.anthropic.com → API Keys
# -------------------------------------------------------

# Anthropic API-Key für KI-Korrektur (wird nur serverseitig verwendet)
ANTHROPIC_API_KEY=sk-ant-...

# -------------------------------------------------------
# CORS-Schutz für den API-Proxy (/api/claude)
# Komma-separierte Liste der erlaubten Origins
# Beispiel: https://meine-app.vercel.app,https://lernortai.ch
# -------------------------------------------------------
ALLOWED_ORIGINS=https://DEINE-DOMAIN.vercel.app

# -------------------------------------------------------
# App-Einstellungen (optional)
# -------------------------------------------------------

# Schulname (wird in der App angezeigt)
SCHOOL_NAME=Berufsschule Musterstadt

# -------------------------------------------------------
# Stripe – Monetarisierung
# https://dashboard.stripe.com → Developers → API Keys
# -------------------------------------------------------

# Stripe Secret Key (serverseitig, nie im Frontend verwenden)
STRIPE_SECRET_KEY=sk_live_...

# Stripe Webhook Secret (aus Stripe Dashboard → Webhooks)
# Benötigte Events: checkout.session.completed, customer.subscription.updated,
#                   customer.subscription.deleted, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (aus Stripe Dashboard → Products)
# Wichtig: Setze metadata.plan = starter | pro | max sowohl am Price als auch am Product
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_MAX=price_...
# Optional für Legacy-Kompatibilität:
STRIPE_PRICE_SCHULE=price_...

# Öffentliche App-URL (ohne trailing slash)
NEXT_PUBLIC_APP_URL=https://lernortai.ch

# Lizenzprüfung deaktivieren (true = keine Lizenz nötig, nur für lokale Entwicklung)
# Standard: Lizenz ist IMMER erforderlich (sicherste Option)
SKIP_LICENSE=false

# Geheimnis für signierte Trial-Tokens (empfohlen: zufälliger 32+ Zeichen String)
# Ohne diesen Wert greift nur das IP-basierte Rate-Limiting als Schutz.
TRIAL_SECRET=

# Admin-E-Mail für interne Benachrichtigungen (Lead-Capture, Enterprise-Anfragen)
ADMIN_EMAIL=info@lernortai.ch

# -------------------------------------------------------
# Resend – E-Mail-Versand
# https://resend.com → API Keys
# -------------------------------------------------------

# Resend API-Key für den Versand des Lizenzschlüssels nach dem Kauf (optional)
RESEND_API_KEY=re_...
